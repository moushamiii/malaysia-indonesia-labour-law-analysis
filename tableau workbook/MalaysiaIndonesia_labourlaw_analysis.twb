    <worksheet name='chart 4'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Time Off Compared: Holidays and Leave Benefits in Indonesia and Malaysia</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='data (Copy of IndonesiaMalaysia_workingtime)' name='federated.0lzpvks1mdi652123pm1f1jicw7a' />
          </datasources>
          <datasource-dependencies datasource='federated.0lzpvks1mdi652123pm1f1jicw7a'>
            <column caption='leave_rest_days_yearly_amount' datatype='real' name='[Calculation_0453838060998657]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([leave_weekly_rest_hours_amount] / 24)*52' />
            </column>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column-instance column='[Calculation_0453838060998657]' derivation='Avg' name='[avg:Calculation_0453838060998657:qk]' pivot='key' type='quantitative' />
            <column-instance column='[leave_annualleave_pay_during_leave_percentage]' derivation='Avg' name='[avg:leave_annualleave_pay_during_leave_percentage:qk]' pivot='key' type='quantitative' />
            <column-instance column='[legalholidayyear]' derivation='Avg' name='[avg:legalholidayyear:qk]' pivot='key' type='quantitative' />
