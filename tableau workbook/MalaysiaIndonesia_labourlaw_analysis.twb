    <worksheet name='chart 3'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Comparison of Legal Work Hours and Overtime Limits: Indonesia vs. Malaysia (2016–2026)</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='data (Copy of IndonesiaMalaysia_workingtime)' name='federated.0lzpvks1mdi652123pm1f1jicw7a' />
          </datasources>
          <datasource-dependencies datasource='federated.0lzpvks1mdi652123pm1f1jicw7a'>
            <column caption='Unified Weekly Overtime Limit' datatype='real' name='[Calculation_0453838040752128]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Country] = &quot;Malaysia&quot; THEN (FLOAT([overtimehours_max_month]) * 12) / 52&#13;&#10;ELSEIF [Country] = &quot;Indonesia&quot; THEN FLOAT([overtimehours_max_week])&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='date' name='[Year]' role='dimension' type='quantitative' />
            <column-instance column='[legalworkhoursweek]' derivation='Avg' name='[avg:legalworkhoursweek:qk]' pivot='key' type='quantitative' />
            <column caption='Legalworkhoursweek' datatype='real' datatype-customized='true' name='[legalworkhoursweek]' role='measure' type='quantitative' />
            <column-instance column='[Country]' derivation='None' name='[none:Country:nk]' pivot='key' type='nominal' />
            <column caption='Overtimehours Max Month' datatype='real' datatype-customized='true' name='[overtimehours_max_month]' role='measure' type='quantitative' />
            <column caption='Overtimehours Max Week' datatype='real' datatype-customized='true' name='[overtimehours_max_week]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0453838040752128]' derivation='Sum' name='[sum:Calculation_0453838040752128:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Year]' derivation='Year-Trunc' name='[tyr:Year:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <aggregation value='true' />
